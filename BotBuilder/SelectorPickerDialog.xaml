<Window x:Class="BotBuilder.SelectorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick target" Height="360" Width="420"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="Choose a target:" Margin="0,0,0,6" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="90" Click="Ok_Click" IsDefault="True" />
            <Button Content="Cancel" Width="90" Margin="8,0,0,0" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
        <ListBox x:Name="Choices" DisplayMemberPath="Display"
                 MouseDoubleClick="Choices_MouseDoubleClick" />
    </DockPanel>
</Window>
